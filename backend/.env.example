# ==================================================
# LEATrace Environment Configuration
# Copy to .env and fill in production values
# ==================================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://leatrace:YOUR_STRONG_PASSWORD@localhost:5432/leatrace
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD

# --- Authentication ---
JWT_SECRET_KEY=GENERATE_WITH_openssl_rand_base64_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Blockchain RPC Providers (optional, public defaults exist) ---
# ETH_RPC_1=https://cloudflare-eth.com
# ETH_RPC_2=https://eth.llamarpc.com
# POLYGON_RPC_1=https://polygon-rpc.com
# BNB_RPC_1=https://bsc-dataseed.binance.org
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# --- Block Explorer API Keys (for higher rate limits) ---
# ETHEREUM_EXPLORER_KEY=your_etherscan_api_key
# POLYGON_EXPLORER_KEY=your_polygonscan_api_key

# --- TRON API Key ---
# TRON_API_KEY=your_trongrid_api_key

# --- HTTP Connection Pool ---
HTTP_TIMEOUT_SECONDS=10
HTTP_CONNECT_TIMEOUT=5
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_PER_HOST=20

# --- Application ---
LEATrace_DEMO_DATA=false
LEATrace_BACKGROUND_TASKS=false
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=/var/log/leatrace/app.log

# --- Docker Compose ---
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
WORKERS=4
