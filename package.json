{
  "name": "leatrace-x",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "install:all": "npm install --prefix frontend && python -m pip install -r backend/requirements.txt",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev": "npx concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/cytoscape": "^3.21.9",
    "@types/uuid": "^10.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "cytoscape": "^3.34.0",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  }
}
